# Knect Contractor Mobile App - Environment Variables Template
# Copy this file to .env and configure the URLs for your environment.
# Prefix variables with EXPO_PUBLIC_ to expose them to the JS runtime.

# --- Backend API URL ---
# - iOS Simulator: http://localhost:8080
# - Android Emulator: http://10.0.2.2:8080
# - Physical Device: http://<your-local-ip>:8080
EXPO_PUBLIC_API_URL=http://localhost:8080

# --- WebSocket API URL ---
# - iOS Simulator: ws://localhost:8080
# - Android Emulator: ws://10.0.2.2:8080
# - Physical Device: ws://<your-local-ip>:8080
EXPO_PUBLIC_WS_URL=ws://localhost:8080
